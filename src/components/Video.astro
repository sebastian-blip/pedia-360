---
interface Props {
  description?: string;
}

const {
  description = "Descubre cómo funciona la membresía y cómo puede ayudarte en el día a día como mamá"
} = Astro.props;
---

<section class="video-section">
  <div class="video-container">
    <div class="video-player">
      <video
        controls
        playsinline
        preload="metadata"
        class="video-element"
      >
        <source src="/videos/presentacion.mp4" type="video/mp4" />
        Tu navegador no soporta videos HTML5.
      </video>
    </div>

    <p class="video-description">
      {description}
    </p>
  </div>
</section>

<style>
  .video-section {
    padding: var(--space-2xl) var(--space-lg);
    background: var(--color-white);
  }

  .video-container {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .video-player {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-lg);
  }

  .video-element {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
    border-radius: 16px;
    box-shadow: var(--shadow-md);
  }

  .video-description {
    max-width: 700px;
    margin: 0 auto;
    font-size: var(--text-lg);
    color: var(--color-gray);
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .video-section {
      padding: var(--space-xl) var(--space-md);
    }

    .video-element {
      max-width: 100%;
    }

    .video-description {
      font-size: var(--text-base);
    }
  }
</style>