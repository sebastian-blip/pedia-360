---
import '../styles/variables.css';
import Button from './Button.astro';
---

<section class="hero">
  <div class="hero-container">
    <div class="hero-content">

      <!-- Logo superior -->
      <div class="hero-logo-top">
        <img
          src="/images/LOGO PEDIA 360 - TEXT.png"
          alt="Pedia360"
          loading="eager"
        />
      </div>

      <h1 class="hero-title">
        Deja de buscar respuestas en Google y empieza a tomar decisiones con tranquilidad sobre la salud y crianza de tu hijo
      </h1>

      <p class="hero-subtitle">
        Pedia360 es un acompañamiento creado por pediatras para mamás con niños de 0 a 5 años que quieren entender qué hacer en cada etapa, sin vivir con miedo, dudas o información contradictoria.
      </p>

      <div class="hero-features">
        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Salud infantil</span>
        </div>

        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Alimentación</span>
        </div>

        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Sueño</span>
        </div>

        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Desarrollo</span>
        </div>

        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Crianza basada en evidencia</span>
        </div>
      </div>

      <div class="hero-cta">
        <Button
          text="QUIERO UNIRME AHORA"
          variant="primary"
          size="lg"
          href="#pricing"
          onClick="gtag('event', 'first_cta_click', { event_category: 'engagement', event_label: 'Hero Section' });"
        />
      </div>

      <div class="hero-cta">
        <Button
          text="VER PLANES"
          variant="primary"
          size="lg"
          href="#pricing"
          onClick="gtag('event', 'second_cta_click', { event_category: 'engagement', event_label: 'Hero Section' });"
        />
      </div>

      <!-- Logo inferior -->
      <div class="hero-logo-bottom">
        <img
          src="/images/logo.png"
          alt="Pedia360"
          loading="lazy"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-2xl) var(--space-lg);
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-container {
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-lg);
    width: 100%;
  }

  .hero-logo-top img {
    width: 200%;
    max-width: 600px;
    height: auto;
    display: block;
  }

  .hero-title {
    font-size: var(--text-4xl);
    color: var(--color-dark);
    line-height: 1.4;
    font-weight: 700;
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-gray);
    line-height: 1.8;
    max-width: 800px;
  }

  .hero-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: center;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-dark);
  }

  .check-icon {
    color: var(--color-pink);
    font-weight: 700;
    font-size: var(--text-lg);
    min-width: 24px;
    text-align: center;
  }

  .hero-cta {
    display: flex;
    justify-content: center;
  }

  .hero-logo-bottom {
    margin-top: var(--space-lg);
  }

  .hero-logo-bottom img {
    width: 100%;
    max-width: 300px;
    height: auto;
    display: block;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-xl) var(--space-md);
      min-height: auto;
    }

    .hero-title {
      font-size: var(--text-2xl);
    }

    .hero-subtitle {
      font-size: var(--text-base);
    }

    .hero-logo-top img {
      max-width: 200px;
    }

    .hero-logo-bottom img {
      max-width: 140px;
    }
  }
</style>