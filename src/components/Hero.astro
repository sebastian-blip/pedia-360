---
import '../styles/variables.css';
import Button from './Button.astro';
---

<section class="hero">
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">
        Deja de buscar respuestas en Google y empieza a tomar decisiones con tranquilidad sobre la salud y crianza de tu hijo
      </h1>
      
      <p class="hero-subtitle">
        Pedia360 es un acompañamiento creado por pediatras para mamás con niños de 0 a 5 años que quieren entender qué hacer en cada etapa, sin vivir con miedo, dudas o información contradictoria.
      </p>

      <div class="hero-features">
        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Salud infantil</span>
        </div>
        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Alimentación</span>
        </div>
        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Sueño</span>
        </div>
        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Desarrollo</span>
        </div>
        <div class="feature-item">
          <span class="check-icon">✔</span>
          <span>Crianza basada en evidencia</span>
        </div>
      </div>

      <div class="hero-cta">
        <Button 
          text="QUIERO UNIRME AHORA" 
          variant="primary" 
          size="lg"
          href="#pricing"
            onClick="gtag('event', 'first_cta_click', { event_category: 'engagement', event_label: 'Hero Section' });"
        />
      </div>
      <div class="hero-cta">
        <Button 
          text="VER PLANES" 
          variant="primary" 
          size="lg"
          href="#pricing"
            onClick="gtag('event', 'second_cta_click', { event_category: 'engagement', event_label: 'Hero Section' });"
        />
      </div>
    </div>

    <div class="hero-image">
      <div class="image-placeholder">
        <img 
          src="/images/logo.png" 
          alt="Mamá con bebé feliz"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-2xl) var(--space-lg);
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .hero-title {
    font-size: var(--text-4xl);
    color: var(--color-dark);
    line-height: 1.4;
    font-weight: 700;
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-gray);
    line-height: 1.8;
  }

  .hero-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-dark);
  }

  .checkmark {
    font-size: var(--text-lg);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-image {
  display: flex;
  justify-content: center;
  align-items: center;
}

.image-placeholder {
  width: 100%;
  max-width: 500px;
}

.image-placeholder img {
  width: 100%;
  height: auto;
  object-fit: contain;
  display: block;
}

   .check-icon {
    color: var(--color-pink);
    font-weight: 700;
    font-size: var(--text-lg);
    min-width: 24px;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-xl) var(--space-md);
      min-height: auto;
    }

    .hero-container {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .hero-title {
      font-size: var(--text-2xl);
    }

    .hero-subtitle {
      font-size: var(--text-base);
    }
  }
</style>